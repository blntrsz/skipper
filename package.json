{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "skipper",
  "packageManager": "bun@1.3.10",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cli": "bun --cwd packages/cli run cli",
    "lint": "biome lint .",
    "format": "biome format --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "deps:check": "turbo run deps:check",
    "sheriff": "sheriff verify \"cli,core,coreRuntime,testRuntime\"",
    "check": "biome check . && bun run typecheck && bun run deps:check && bun run sheriff",
    "check:fix": "biome check --write . && bun run typecheck && bun run deps:check && bun run sheriff",
    "test:e2e:issue-subscription": "bun run ./scripts/verify-issue-subscription-e2e.ts",
    "build": "turbo run build",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@changesets/cli": "^2.30.0",
    "@softarc/sheriff-core": "^0.19.6",
    "@types/bun": "latest",
    "dependency-cruiser": "^17.3.9",
    "turbo": "^2.5.8",
    "typescript": "^5"
  }
}
