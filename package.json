{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "skipper",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "cli": "bun run ./packages/cli/src/index.ts",
    "lint": "oxlint .",
    "format": "oxfmt --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "sheriff": "bunx sherif@latest",
    "sheriff:fix": "bunx sherif@latest --fix",
    "check": "bun run format && bun run lint && bun run typecheck && bun run sheriff",
    "check:fix": "oxfmt --write . && oxlint --fix . && bun run typecheck && bun run deps:check && bun run sheriff:fix",
    "test:e2e:issue-subscription": "bun run ./scripts/verify-issue-subscription-e2e.ts",
    "build": "turbo run build",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "effect-tsgo patch",
    "knip": "knip"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@effect/language-service": "^0.84.1",
    "@effect/tsgo": "0.0.15",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "dependency-cruiser": "^17.3.9",
    "knip": "^6.0.6",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.5.8",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.10"
}
