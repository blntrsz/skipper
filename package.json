{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@skippercorp/skipper",
  "version": "1.4.6",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts"
  ],
  "bin": {
    "sk": "./bin/skipper"
  },
  "scripts": {
    "cli": "bun run ./src/Cli.ts",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "deps:check": "depcruise --config .dependency-cruiser.cjs src",
    "test:e2e:issue-subscription": "bun run ./scripts/verify-issue-subscription-e2e.ts",
    "build": "bun build ./src/Cli.ts --target bun-darwin-arm64 --compile --outfile bin/skipper",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest",
    "dependency-cruiser": "^17.3.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.1007.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1007.0",
    "@aws-sdk/client-ec2": "^3.1007.0",
    "@aws-sdk/client-ecs": "^3.1007.0",
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/client-sts": "^3.1007.0",
    "@effect/platform-bun": "4.0.0-beta.30",
    "@effect/sql-sqlite-bun": "4.0.0-beta.30",
    "@effect/vitest": "4.0.0-beta.30",
    "@octokit/webhooks": "^14.2.0",
    "@octokit/webhooks-types": "^7.6.1",
    "commander": "^14.0.3",
    "effect": "4.0.0-beta.30",
    "ulid": "^3.0.2"
  }
}
