{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "skipper",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "cli": "bun --filter '@skippercorp/skipper-cli' cli",
    "lint": "oxlint .",
    "format": "oxfmt --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "deps:check": "turbo run deps:check",
    "sheriff": "sheriff verify \"cli,core,coreRuntime,testRuntime\"",
    "check": "bun run format && bun run lint && bun run typecheck && bun run deps:check && bun run sheriff",
    "check:fix": "oxfmt --write . && oxlint --fix . && bun run typecheck && bun run deps:check && bun run sheriff",
    "test:e2e:issue-subscription": "bun run ./scripts/verify-issue-subscription-e2e.ts",
    "build": "turbo run build",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "dependencies": {
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@faker-js/faker": "^10.3.0",
    "@softarc/sheriff-core": "^0.19.6",
    "@types/bun": "latest",
    "dependency-cruiser": "^17.3.9",
    "turbo": "^2.5.8",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.10"
}
