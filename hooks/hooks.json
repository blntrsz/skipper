{
  "description": "Mirror Claude Code sessions into skipper",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/track-claude-session.ts\"",
            "timeout": 30,
            "statusMessage": "Sync skipper session"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/track-claude-session.ts\"",
            "timeout": 30,
            "statusMessage": "Sync skipper session"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/track-claude-session.ts\"",
            "timeout": 30,
            "statusMessage": "Sync skipper session"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/track-claude-session.ts\"",
            "timeout": 30,
            "statusMessage": "Sync skipper session"
          }
        ]
      }
    ]
  }
}
