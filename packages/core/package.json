{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@skippercorp/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./common/sql": "./src/common/sql.ts",
    "./runtime/local-work-tree.runtime": "./src/runtime/local-work-tree.runtime.ts",
    "./runtime/docker.runtime": "./src/runtime/docker.runtime.ts",
    "./common/adapter/*": "./src/common/adapter/*.ts",
    "./common/docker": "./src/common/docker.ts",
    "./*": "./src/*/index.ts"
  },
  "scripts": {
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "deps:check": "depcruise --config ../../.dependency-cruiser.cjs src",
    "build": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.30",
    "@effect/sql-sqlite-bun": "4.0.0-beta.30",
    "@effect/vitest": "4.0.0-beta.30",
    "@opencode-ai/sdk": "^1.3.0",
    "effect": "4.0.0-beta.30",
    "ulid": "^3.0.2"
  }
}
