{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@skippercorp/skipper-cli",
  "version": "0.2.4",
  "private": false,
  "bin": {
    "sk": "./bin/skipper"
  },
  "files": [
    "bin/**/*",
    "src/**/*.ts",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "cli": "bun run ./src/index.ts",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "test": "bun x --bun vitest run",
    "deps:check": "bun x tsc --noEmit -p tsconfig.json",
    "build": "bun build ./src/index.ts --target bun-darwin-arm64 --compile --outfile bin/skipper"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.30",
    "effect": "4.0.0-beta.30"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.30",
    "@skippercorp/core": "workspace:*",
    "vitest": "4.0.18"
  }
}
